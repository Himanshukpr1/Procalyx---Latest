{
  "name": "procalyx-web-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright end-to-end tests for Procalyx",
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:all": "playwright test",
    "test:authenticated": "playwright test --project=chromium-authenticated",
    "test:authenticated:only": "playwright test --project=chromium-authenticated",
    "test:authenticated-suite": "playwright test tests/specs/login.spec.js tests/specs/user-management.authenticated.spec.js tests/specs/hospital-masters.authenticated.spec.js tests/specs/hospital-unit-masters.authenticated.spec.js tests/specs/manufacturer-masters-ap.authenticated.spec.js tests/specs/manufacturer-item.authenticated.spec.js tests/specs/affordplan-master-submodules.authenticated.spec.js tests/specs/item-master.authenticated.spec.js tests/specs/dashboard.smoke.authenticated.spec.js --project=chromium --project=chromium-authenticated --workers=1",
    "test:ap-operator-suite": "AUTH_PROFILE=ap_operator playwright test tests/specs/login.spec.js tests/specs/manufacturer-item.authenticated.spec.js tests/specs/affordplan-master-submodules.authenticated.spec.js tests/specs/item-master.authenticated.spec.js tests/specs/dashboard.smoke.authenticated.spec.js --project=chromium --project=chromium-authenticated --workers=1",
    "test:ap-operator-suite:flow": "AUTH_PROFILE=ap_operator playwright test tests/specs/login.spec.js tests/specs/manufacturer-item.authenticated.spec.js tests/specs/affordplan-master-submodules.authenticated.spec.js tests/specs/item-master.authenticated.spec.js tests/specs/dashboard.smoke.authenticated.spec.js --grep '@sanity|@login-email|@login|@manufacturer-item|@affordplan-master-sub|@item-master|@dashboard-smoke' --project=chromium --project=chromium-authenticated --workers=1",
    "test:hkam-operator-suite": "AUTH_PROFILE=hkam_operator playwright test tests/specs/login.spec.js tests/specs/hospital-masters.authenticated.spec.js tests/specs/hospital-unit-masters.authenticated.spec.js --project=chromium --project=chromium-authenticated --workers=1",
    "test:hkam-operator-suite:flow": "AUTH_PROFILE=hkam_operator playwright test tests/specs/login.spec.js tests/specs/hospital-masters.authenticated.spec.js tests/specs/hospital-unit-masters.authenticated.spec.js --grep '@sanity|@login-email|@login|@hospital-master|@hospital-unit-master' --project=chromium --project=chromium-authenticated --workers=1",
    "test:sanity": "playwright test --grep @sanity --project=chromium --workers=1",
    "test:login-headed": "playwright test tests/specs/login.spec.js --project=chromium --headed --workers=1",
    "test:otp": "npm run test:sanity",
    "test:logged-in": "npm run test:authenticated",
    "test:user-mgmt": "playwright test tests/specs/user-management.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:user-mgmt:affordplan": "playwright test tests/specs/user-management.authenticated.spec.js --grep '@login|@affordplan' --project=chromium-authenticated --workers=1",
    "test:user-mgmt:hospital": "playwright test tests/specs/user-management.authenticated.spec.js --grep '@login|@hospital' --project=chromium-authenticated --workers=1",
    "test:user-mgmt:manufacturer": "playwright test tests/specs/user-management.authenticated.spec.js --grep '@login|@manufacturer' --project=chromium-authenticated --workers=1",
    "test:hospital-masters": "playwright test tests/specs/hospital-masters.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:hospital-masters:flow": "playwright test tests/specs/hospital-masters.authenticated.spec.js --grep '@login|@hospital-master' --project=chromium-authenticated --workers=1",
    "test:hospital-unit-masters": "playwright test tests/specs/hospital-unit-masters.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:hospital-unit-masters:flow": "playwright test tests/specs/hospital-unit-masters.authenticated.spec.js --grep '@login|@hospital-unit-master' --project=chromium-authenticated --workers=1",
    "test:manufacturer-masters-ap": "playwright test tests/specs/manufacturer-masters-ap.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:manufacturer-masters-ap:flow": "playwright test tests/specs/manufacturer-masters-ap.authenticated.spec.js --grep '@login|@manufacturer-masters-ap|@manufacturer-onboarding' --project=chromium-authenticated --workers=1",
    "test:manufacturer-item": "playwright test tests/specs/manufacturer-item.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:manufacturer-item:flow": "playwright test tests/specs/manufacturer-item.authenticated.spec.js --grep '@login|@manufacturer-item' --project=chromium-authenticated --workers=1",
    "test:affordplan-master-sub": "playwright test tests/specs/affordplan-master-submodules.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:affordplan-master-sub:flow": "playwright test tests/specs/affordplan-master-submodules.authenticated.spec.js --grep '@login|@affordplan-master-sub' --project=chromium-authenticated --workers=1",
    "test:item-master": "playwright test tests/specs/item-master.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:item-master:flow": "playwright test tests/specs/item-master.authenticated.spec.js --grep '@login|@item-master' --project=chromium-authenticated --workers=1",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen",
    "install:browsers": "playwright install --with-deps",
    "test:auth:save": "node tests/scripts/save-auth-session.js",
    "test:auth:save:ap-operator": "AUTH_PROFILE=ap_operator node tests/scripts/save-auth-session.js",
    "test:auth:save:hkam-operator": "AUTH_PROFILE=hkam_operator node tests/scripts/save-auth-session.js",
    "test:manufacturer-item:ap-operator": "AUTH_PROFILE=ap_operator playwright test tests/specs/manufacturer-item.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:manufacturer-item:ap-operator:flow": "AUTH_PROFILE=ap_operator playwright test tests/specs/manufacturer-item.authenticated.spec.js --grep '@login|@manufacturer-item' --project=chromium-authenticated --workers=1",
    "test:affordplan-master-sub:ap-operator": "AUTH_PROFILE=ap_operator playwright test tests/specs/affordplan-master-submodules.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:affordplan-master-sub:ap-operator:flow": "AUTH_PROFILE=ap_operator playwright test tests/specs/affordplan-master-submodules.authenticated.spec.js --grep '@login|@affordplan-master-sub' --project=chromium-authenticated --workers=1",
    "test:item-master:ap-operator": "AUTH_PROFILE=ap_operator playwright test tests/specs/item-master.authenticated.spec.js --project=chromium-authenticated --workers=1",
    "test:item-master:ap-operator:flow": "AUTH_PROFILE=ap_operator playwright test tests/specs/item-master.authenticated.spec.js --grep '@login|@item-master' --project=chromium-authenticated --workers=1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  },
  "engines": {
    "node": ">=18"
  }
}
